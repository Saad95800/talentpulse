generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  relationMode = "prisma"
}

enum Role {
  ADMIN
  USER
}

model User {
  id                String        @id @default(uuid())
  email             String        @unique
  name              String?
  phone             String
  password          String
  role              Role          @default(USER)
  credits           Int           @default(3)
  lastCreditReset   DateTime?     // Date de la dernière réinitialisation quotidienne
  isVerified        Boolean       @default(false)
  verificationToken String?       @unique
  matches           MatchRecord[]
  missions          Mission[]     // Relation vers les offres de missions
  candidates        Candidate[]   // Relation vers les candidats
  activities        UserActivity[] // Historique d'activité
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // ─── Facturation (Mollie) ─────────────────────────────
  mollieCustomerId       String?    // ID Client Mollie
  mollieSubscriptionId   String?    // ID Subscription Mollie
  plan                   String     @default("FREE") // "FREE", "PREMIUM"
  subscriptionStatus     String?    // "active", "canceled", "suspended"
  nextBillingDate        DateTime?
  payments               MolliePayment[]
  batchJobs              BatchJob[]
}

model BatchJob {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  status          String         @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  totalItems      Int
  processedItems  Int            @default(0)
  items           BatchItem[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId])
}

model BatchItem {
  id              String         @id @default(uuid())
  batchJobId      String
  batchJob        BatchJob       @relation(fields: [batchJobId], references: [id])
  candidateName   String?
  cvText          String?        @db.LongText
  status          String         @default("PENDING")
  matchRecordId   String?        @unique
  matchRecord     MatchRecord?   @relation(fields: [matchRecordId], references: [id])
  error           String?        @db.Text
  createdAt       DateTime       @default(now())

  @@index([batchJobId])
}

model Mission {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  title       String        @db.Text
  description String        @db.LongText
  matches     MatchRecord[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId])
}

model Candidate {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  name        String        @db.Text
  firstName   String?       @db.Text
  lastName    String?       @db.Text
  email       String?       @db.Text
  phone       String?       @db.Text
  address     String?       @db.Text
  linkedin    String?       @db.Text
  website     String?       @db.Text
  summary     String?       @db.LongText
  languages   Json?
  skills      Json?
  experiences Json?
  educations  Json?
  cvText      String        @db.LongText
  matches     MatchRecord[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId])
}

model MatchRecord {
  id            String     @id @default(uuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id])
  missionId     String?
  mission       Mission?   @relation(fields: [missionId], references: [id])
  candidateId   String?
  candidate     Candidate? @relation(fields: [candidateId], references: [id])
  jobTitle      String
  candidateName String
  score         Float
  aiResponse    Json
  batchItem     BatchItem?
  createdAt     DateTime   @default(now())

  @@index([userId])
  @@index([missionId])
  @@index([candidateId])
}

model AppSettings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppLog {
  id        String   @id @default(uuid())
  level     String   // "ERROR", "WARN", "INFO"
  message   String   @db.Text
  stack     String?  @db.Text
  userId    String?
  context   String?  @db.Text // JSON string for extra info
  createdAt DateTime @default(now())

  @@index([level])
  @@index([createdAt])
}

model UserActivity {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String   // "PAGE_VIEW", "CLICK", "POPUP_OPEN", "MATCHING_START", etc.
  description String?  @db.Text
  path        String?  @db.Text
  target      String?  @db.Text
  metadata    Json?    // Données contextuelles additionnelles
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model MolliePayment {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  amount           Float    // Montant total en euros
  currency         String   @default("EUR")
  molliePaymentId  String   @unique
  method           String?  // "card", "ideal", etc.
  status           String   // "paid", "failed", "expired"
  receiptNumber    String   @unique // ex: RECU-2026-0001
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
